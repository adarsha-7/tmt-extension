{
    "manifest_version": 2,
    "name": "TMT Trilingual Translator",
    "version": "1.0",
    "description": "Translate between English, Nepali, and Tamang in real-time",
    "permissions": [
        "activeTab",
        "storage",
        "contextMenus",
        "identity",
        "http://localhost:3000/*",
        "https://tmt.ilprl.ku.edu.np/*",
        "<all_urls>"
    ],
    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "tmt-translator@yourname.com",
            "strict_min_version": "57.0"
        }
    }
}
