{
    "manifest_version": 2,
    "name": "TMT Trilingual Translator",
    "version": "1.0",
    "description": "Translate between English, Nepali, and Tamang in real-time",
    "permissions": ["activeTab", "storage", "contextMenus", "http://localhost:3000/*"],
     "permissions": ["identity", 
	 "contextMenus",
	 "activeTab",
	 "scripting",
	 "storage",
	 "<all_urls>"
     ],
    "background": {
        "scripts": ["background.js" , "imageTranslator/background.js"],
        "persistent": false
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        },
	{
	    "matches" : ["<all_urls>"],
	    "js" : ["imageTranslator/content.js"]
	}
    ],
    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
